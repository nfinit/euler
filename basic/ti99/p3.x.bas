REM * PROJECT EULER - 03 *
REM  LARGEST PRIME FACTOR
REM **********************
REM SOLUTION FOR TI 99/4A
REM EXTENDED BASIC ONLY

1 CALL CLEAR :: CALL SCREEN(15)
2 FACTOR,FOUND,P,K=0

10 INPUT "NUMBER TO FACTOR: ":N
11 IF N=0 THEN 999
12 IF N<0 THEN 10

20 CALL CLEAR :: CALL SCREEN(12)
21 PRINT "FACTORING:",N
22 FACTOR=2
23 IF N<2 THEN 90
24 IF N-FACTOR*INT(N/FACTOR)>0 THEN 26
25 FOUND = FOUND+1 :: PRINT FACTOR; :: IF FOUND=1 THEN PRINT ",";
26 N=INT(N/F)
27 GOTO 23

90 PRINT "" :: PRINT "" :: CALL SCREEN(4)
92 CALL SOUND(100,932,10) :: CALL SOUND (400,1175,10)
93 PRINT "ALL FACTORS FOUND"
99 END
