1 DEF MOD(A,B)=A-B*INT(A/B)
2 INPUT "TEST VALUE: ":P
3 IF P<1 THEN 999
4 PRINT "PROCESSING..."
  
REM * INITIAL INPUT CHECKS *
10 IF P>1 THEN 11 ELSE 90
11 IF P>3 THEN 12 ELSE 92
12 IF MOD(P,2)=0 THEN 90
13 IF MOD(P,3)=0 THEN 90

REM * MAIN LOOP *
20 MAX=SQR(P)
21 FOR I=5 TO MAX
22  IF MOD(P,I)=0 THEN 90
23  IF MOD(P,I+2)=0 THEN 90
28  I=I+5
29 NEXT I

REM * NON-PRIME *
90 PRINT P,"NONPRIME"
91 GOTO 98

REM * PRIME *
92 PRINT P,"PRIME"
93 GOTO 98

98 PAUSE
99 GOTO 2
               
999 END
