1 CALL CLEAR
2 INPUT "ENTER VALUE TO TEST:":X

10 IF X>1 THEN 11 ELSE 90
11 IF X>3 THEN 12 ELSE 91
12 M=X-2*INT(X/2)
13 IF M=0 THEN 90
14 M=X-3*INT(X/3)
15 IF M=0 THEN 90
16 I=5
17 IF I=X THEN 23
18 M=X-I*INT(X/I)
19 IF M=0 THEN 90
20 IF X=I+2 THEN 23
21 M=X-(I+2)*INT(X/(I+2))
22 IF M=0 THEN 90
23 I=I+6
24 IF (I^2-X)>0 THEN 91
90 P=0 :: GOTO 98
91 P=1 :: GOTO 98

98 IF P=1 THEN PRINT "PRIME" ELSE PRINT "NOT PRIME"
