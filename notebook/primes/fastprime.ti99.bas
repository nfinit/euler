1 CALL CLEAR
2 DEF MOD(A,B)=A-B*INT(A/B)
3 INPUT "TEST VALUE: ":P
4 IF P<1 THEN 999
5 PRINT "PROCESSING..."
6 PRINT ""
  
REM * INITIAL INPUT CHECKS *
10 IF P<2 THEN 90
11 IF P<4 THEN 92
12 IF MOD(P,2)=0 THEN 90
13 IF MOD(P,3)=0 THEN 90

REM * MAIN LOOP*
20 MAX=SQR(P)
21 FOR I=5 TO MAX STEP 6
22  IF MOD(P,I)=0 THEN 90
23  IF MOD(P,I+2)=0 THEN 90
29 NEXT I
          
REM * FINAL OUTPUT *
90 PRINT P,"IS NONPRIME"
91 GOTO 98
92 PRINT P,"IS PRIME"
93 GOTO 98

98 PRINT ""
99 GOTO 2
               
999 END
