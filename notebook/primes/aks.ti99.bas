1 CALL CLEAR
2 INPUT "ENTER VALUE TO TEST: ":X
3 CALL CLEAR
4 PRINT "CHECKING..."

REM * INITIAL INPUT CHECKS *
10 IF X>1 THEN 11 ELSE 90
11 IF X>3 THEN 12 ELSE 92
12 IF (X-2*INT(X/2))=0 THEN 90
13 IF (X-3*INT(X/3))=0 THEN 90

REM * MAIN LOOP *
16 I=5
17 IF I=X THEN 23
18    IF (X-I*INT(X/I))=0 THEN 90
20    IF X=I+2 THEN 23 
21    IF (X-(I+2)*INT(X/(I+2)))=0 THEN 90
23    I=I+6 
24 IF (I^2-X)>0 THEN 92 ELSE 17 

REM * NON-PRIME *
90 P=0
91 GOTO 97

REM * PRIME *
92 P=1
93 GOTO 95

95 PRINT X,"IS PRIME"
96 GOTO 99
97 PRINT X,"IS NOT PRIME"
98 GOTO 99
                  
99 END
