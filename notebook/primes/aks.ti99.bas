1 CALL CLEAR
2 INPUT "TEST VALUE: ":P
3 IF P<1 THEN 999
4 PRINT "PROCESSING..."
5 PRINT ""
  
REM * INITIAL INPUT CHECKS *
10 IF P<2 THEN 90
11 IF P<4 THEN 92
12 IF (P-2*INT(P/2))=0 THEN 90
13 IF (P-3*INT(P/3))=0 THEN 90

REM * MAIN LOOP *
20 I=5
21 IF I=P THEN 25
22 IF (P-I*INT(P/I))=0 THEN 90
23 IF P=I+2 THEN 25
24 IF (P-(I+2)*INT(P/(I+2)))=0 THEN 90
25 I=I+6 
26 IF (I^2-P)>0 THEN 92 ELSE 21 
30 PRINT ""

REM * FINAL OUTPUT *
90 PRINT P,"IS NONPRIME"
91 GOTO 98
92 PRINT P,"IS PRIME"
93 GOTO 98

98 PRINT ""
99 GOTO 2
               
999 END
