1 CALL CLEAR
2 INPUT "TEST VALUE: ":P
3 IF P<1 THEN 999
4 PRINT "PROCESSING..."
5 PRINT ""
  
REM * INITIAL INPUT CHECKS *
10 IF P>1 THEN 11 ELSE 90
11 IF P>3 THEN 12 ELSE 92
12 IF (P-2*INT(P/2))=0 THEN 90
13 IF (P-3*INT(P/3))=0 THEN 90

REM * MAIN LOOP *
16 I=5
17 IF I=P THEN 23
18    IF (P-I*INT(P/I))=0 THEN 90
20    IF P=I+2 THEN 23 
21    IF (P-(I+2)*INT(P/(I+2)))=0 THEN 90
23    I=I+6 
24 IF (I^2-P)>0 THEN 92 ELSE 17 

REM * NON-PRIME *
90 PRINT P,"IS NONPRIME"
91 GOTO 98

REM * PRIME *
92 PRINT P,"IS PRIME"
93 GOTO 98

98 PRINT ""
99 GOTO 2
               
999 END
